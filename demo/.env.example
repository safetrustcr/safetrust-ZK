# Copy to demo/.env.local (or demo/.env)

# Pollar — https://dashboard.pollar.xyz
# Add http://localhost:3000 under Configuration → Domains
NEXT_PUBLIC_POLLAR_PUBLISHABLE_KEY=pub_testnet_xxxxxxxxxxxxxxxxxxxx
POLLAR_SECRET_KEY=sec_testnet_xxxxxxxxxxxxxxxxxxxx

# Optional — host only, no trailing /v1 (SDK adds /v1 automatically)
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_POLLAR_BASE_URL=https://sdk.api.pollar.xyz
NEXT_PUBLIC_POLLAR_ACCENT_COLOR=#8B5CF6

NEXT_PUBLIC_TRUSTLESS_API_URL=https://api.trustlesswork.com
